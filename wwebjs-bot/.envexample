# LivSight WhatsApp bot — environment example
# Copy to `.env` and fill in real values. Never commit `.env`.
#
# Deploy runbook: wwebjs-bot/docs/DEPLOY_STAGING.md

# =============================================================================
# Staging bot VPS — full `.env` (copy block below, then fill secrets)
# =============================================================================
# NODE_ENV=production
# USE_CORE_API=true
# SKIP_MIGRATIONS=true
#
# CORE_API_BASE_URL=https://staging-gateway.livsight.com
#
# CORE_BOT_USERNAME=whatsapp-bot
# CORE_BOT_PASSWORD=<staging password for whatsapp-bot>
#
# CORE_DEPARTURE_CITY=Douala
# CORE_DEPARTURE_REGION=Littoral
# CORE_DEPARTURE_STREET=Bonapriso Shop
# CORE_DESTINATION_CITY=Douala
# CORE_DESTINATION_REGION=Littoral
# CORE_DESTINATION_STREET=N/A
#
# CLIENT_ID=livsight-bot-core-staging
#
# AI_DELIVERY_FALLBACK_ENABLED=true
# OPENAI_API_KEY=<your OpenAI API key>
#
# BOT_ALERT_WEBHOOK_URL=<Discord webhook URL for bot alerts>
# =============================================================================

# ---------------------------
# Core mode (staging bot VPS — recommended)
# ---------------------------
# USE_CORE_API=true     → orders go to backend_core (not local deliveries table)
# SKIP_MIGRATIONS=true  → bot does not create groups/deliveries tables on shared DB
USE_CORE_API=false
SKIP_MIGRATIONS=false

# ---------------------------
# Database (legacy mode / optional Express API only)
# ---------------------------
# Not required when USE_CORE_API=true (gateway-only bot).
# Required for legacy bot (USE_CORE_API=false) or npm run api:dev:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME
# PG_SSL=false

# ---------------------------
# Server
# ---------------------------
API_PORT=3000
# VPS: production | local: development
NODE_ENV=development
TIME_ZONE=Africa/Douala
ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------
# Auth (legacy Express API — optional)
# ---------------------------
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
AUTH_HEADER_FALLBACK=true

# ---------------------------
# LivSight core API (separate core VPS — NOT the bot VPS)
# ---------------------------
# Gateway / API base (auth → {CORE_API_BASE_URL}/auth/login):
CORE_API_BASE_URL=https://staging-gateway.livsight.com
# Local dev:
# CORE_API_BASE_URL=http://localhost:4040

CORE_BOT_USERNAME=whatsapp-bot
CORE_BOT_PASSWORD=

CORE_DEPARTURE_CITY=Douala
CORE_DEPARTURE_REGION=Littoral
CORE_DEPARTURE_STREET=Bonapriso Shop
CORE_DESTINATION_CITY=Douala
CORE_DESTINATION_REGION=Littoral
CORE_DESTINATION_STREET=N/A

# ---------------------------
# WhatsApp session
# ---------------------------
# Isolates dev / staging / prod sessions (do not reuse across environments)
# VPS core bot: livsight-bot-core-staging | local: livsight-bot-staging
CLIENT_ID=livsight-bot-core-staging
# Optional: process only this group (id from #link)
GROUP_ID=

SEND_CONFIRMATIONS=false
REPORT_ENABLED=false
REPORT_TIME=20:00
FORMAT_REMINDER_ENABLED=true

# ---------------------------
# AI fallback (recommended on staging)
# ---------------------------
# Parses messy WhatsApp lines + quantity when regex fails
AI_DELIVERY_FALLBACK_ENABLED=true
OPENAI_API_KEY=

# ---------------------------
# Discord alerts (recommended on staging)
# ---------------------------
# Server Settings → Integrations → Webhooks → New Webhook → copy URL
BOT_ALERT_WEBHOOK_URL=

# ---------------------------
# Cloudinary (optional)
# ---------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

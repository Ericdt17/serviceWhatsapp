# LivSight - wwebjs-bot environment example
# Copy this file to `.env` and fill in real values.

# ---------------------------
# Database
# ---------------------------
# Postgres on staging/production server (not local Docker).
# If unset, the bot falls back to SQLite (local dev only).
DB_TYPE=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME
PG_SSL=false
# Shared core DB — set SKIP_MIGRATIONS=true so bot does not create groups/deliveries tables
SKIP_MIGRATIONS=false
USE_CORE_API=false

# ---------------------------
# Server
# ---------------------------
API_PORT=3000
NODE_ENV=development
TIME_ZONE=UTC

# Comma-separated list of allowed origins (CORS). Must include your frontend URL(s).
ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------
# Auth (REQUIRED)
# ---------------------------
# Required for login (do NOT use a placeholder in real envs)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Enable Bearer token auth (Authorization header) as fallback.
# Useful for mobile apps that cannot use HTTP-only cookies.
AUTH_HEADER_FALLBACK=true

# ---------------------------
# LivSight core API (gateway)
# ---------------------------
# Staging gateway (not core-service :8085 direct)
CORE_API_BASE_URL=http://156.67.27.35:4000
CORE_AUTH_URL=http://156.67.27.35:4000/auth/login
CORE_BOT_USERNAME=
CORE_BOT_PASSWORD=
CORE_DEPARTURE_CITY=Douala
CORE_DEPARTURE_REGION=Littoral
CORE_DEPARTURE_STREET=
CORE_DESTINATION_CITY=Douala
CORE_DESTINATION_REGION=Littoral
CORE_DESTINATION_STREET=N/A

# ---------------------------
# Bot behavior (optional)
# ---------------------------
# WhatsApp LocalAuth session id (isolates dev/staging/prod sessions)
CLIENT_ID=livsight-bot-staging
# WhatsApp group id like: 1234567890-1234567890@g.us
GROUP_ID=

SEND_CONFIRMATIONS=false

# Daily report settings (if you have a scheduler enabled)
REPORT_ENABLED=false
REPORT_TIME=20:00

# When a message looks like a delivery but strict parse fails,
# send a reminder with accepted formats.
FORMAT_REMINDER_ENABLED=true

# ---------------------------
# Alerts / Webhooks (optional)
# ---------------------------
# Example: Discord webhook URL for bot alerts
BOT_ALERT_WEBHOOK_URL=

# ---------------------------
# AI (optional)
# ---------------------------
OPENAI_API_KEY=
AI_DELIVERY_FALLBACK_ENABLED=false

# ---------------------------
# Cloudinary (optional)
# ---------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

